#!/bin/bash
# kugui debug-queue smoke (30 min, 1× A100): CUDA compile check + device
# correctness gates + the 4³ point. Submit from the repo root on kugui:
#   /opt/pbs/bin/qsub bench/gpu/job_i1accs.pbs
#PBS -q i1accs
#PBS -l select=1:ncpus=16:ngpus=1
#PBS -l walltime=00:30:00
#PBS -N sce-gpu-smoke
cd "$PBS_O_WORKDIR"
~/.juliaup/bin/julia -t 8 --project=bench/gpu bench/bench_gpu.jl 4 50 \
    > bench/gpu/smoke_i1accs.log 2>&1
